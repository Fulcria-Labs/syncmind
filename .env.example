# SyncMind Environment Configuration
# Copy to .env and fill in your values

# AI Provider - set ONE for cloud AI, or leave ALL blank to use Ollama locally
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama Local AI (used when no cloud API key is set)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b-instruct-q4_K_M
